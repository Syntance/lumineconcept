## 5. PAYMENT PROVIDER INTEGRATION — Best Practices

### 5.1 Przelewy24 (P24) Module Structure (Medusa v2)

**Folder**: `apps/backend/src/modules/przelewy24/`

```
przelewy24/
├── index.ts          # Module definition
└── service.ts        # P24Service extends AbstractPaymentProvider
```

**Service** (`service.ts`):
```typescript
import { AbstractPaymentProvider } from "@medusajs/framework/utils";
import type {
  InitiatePaymentInput,
  InitiatePaymentOutput,
  AuthorizePaymentInput,
  AuthorizePaymentOutput,
  GetPaymentStatusInput,
  GetPaymentStatusOutput,
  ProviderWebhookPayload,
  WebhookActionResult,
} from "@medusajs/framework/types";

export default class Przelewy24PaymentService extends AbstractPaymentProvider {
  static identifier = "przelewy24";

  async initiatePayment(input: InitiatePaymentInput): Promise<InitiatePaymentOutput> {
    // 1. Kwota z workflow (już zweryfikowana)
    let amountGrosz = this.toGrosz(input.amount);
    
    // 2. Generate sign
    const sessionId = `p24_${crypto.randomUUID()}`;
    const sign = this.sign({ sessionId, merchantId, amount: amountGrosz, currency: "PLN", crc });

    // 3. Register transaction
    const result = await this.api<{ data: { token: string } }>(
      "/transaction/register",
      "POST",
      {
        merchantId,
        posId,
        sessionId,
        amount: amountGrosz,
        currency: "PLN",
        // ... urlReturn, urlStatus
        sign,
      },
      { signal: AbortSignal.timeout(30_000) }, // TIMEOUT obowiązkowy
    );

    return {
      id: sessionId,
      data: {
        p24_session_id: sessionId,
        token: result.data.token,
        redirect_url: `${this.redirectBaseUrl}/trnRequest/${result.data.token}`,
        amount_grosz: amountGrosz,
        currency: "PLN",
        status: "pending",
      },
    };
  }

  async authorizePayment(input: AuthorizePaymentInput): Promise<AuthorizePaymentOutput> {
    const data = input.data as Przelewy24SessionData;
    
    // Pull-based potwierdzenie (niezależne od webhooka)
    const confirmed = await this.confirmFromP24(data);
    if (confirmed.paid) {
      return { status: "captured", data: confirmed.data };
    }
    return { status: "pending", data };
  }

  async getWebhookActionAndData(
    payload: ProviderWebhookPayload["payload"],
  ): Promise<WebhookActionResult> {
    // Weryfikacja podpisu + transaction/verify
    // ... (patrz sekcja 1.5)
  }

  private async confirmFromP24(data: Przelewy24SessionData) {
    // Pull status z P24 API + verify
    // ...
  }
}
```

**NEVER**: Nie hardcoduj `P24_MERCHANT_ID` / `P24_CRC` w kodzie. Zawsze ENV.

