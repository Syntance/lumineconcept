### 1.5 Webhook Signature Verification (CRITICAL)

**Przelewy24 Webhook** (Medusa v2 używa `getWebhookActionAndData` w payment provider):

```typescript
// W payment provider service (przelewy24/service.ts)
async getWebhookActionAndData(
  payload: ProviderWebhookPayload["payload"],
): Promise<WebhookActionResult> {
  const body = (payload.data ?? {}) as Record<string, unknown>;
  const merchantId = Number(body.merchantId);
  const sessionId = String(body.sessionId ?? "");
  const amount = Number(body.amount);
  const currency = String(body.currency ?? "");
  const orderId = Number(body.orderId);
  const receivedSign = String(body.sign ?? "");

  if (!sessionId || !orderId) {
    return { action: PaymentActions.NOT_SUPPORTED };
  }

  // Weryfikuj podpis PRZED jakąkolwiek logiką
  const expectedSign = this.sign({
    merchantId,
    posId: Number(this.options_.posId),
    sessionId,
    amount,
    originAmount: Number(body.originAmount),
    currency,
    orderId,
    methodId: Number(body.methodId),
    statement: String(body.statement ?? ""),
    crc: this.options_.crc,
  });

  if (expectedSign !== receivedSign) {
    this.logger_.error(`[przelewy24] webhook: niezgodny podpis`);
    return { action: PaymentActions.FAILED };
  }

  // Teraz dopiero verify transaction w P24 API
  const verifySign = this.sign({
    sessionId,
    orderId,
    amount,
    currency,
    crc: this.options_.crc,
  });
  
  try {
    await this.api("/transaction/verify", "PUT", {
      merchantId,
      posId: Number(this.options_.posId),
      sessionId,
      amount,
      currency,
      orderId,
      sign: verifySign,
    });
  } catch (e) {
    this.logger_.error(`[przelewy24] webhook verify failed: ${(e as Error).message}`);
    return { action: PaymentActions.FAILED };
  }

  return {
    action: PaymentActions.SUCCESSFUL,
    data: { session_id: sessionId, amount },
  };
}
```

**NEVER**: Nie ufaj query params w URL (`?status=success`). Zawsze weryfikuj podpis i pull status z API providera.

