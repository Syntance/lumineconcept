### 2.2 Circuit Breaker Pattern (Payment Providers)

**Problem**: P24 pada → 100% transakcji failuje → checkout nie działa.

**Solution**: Client-side circuit breaker → fallback na bank transfer.

**Implementation** (`lib/checkout/p24-circuit-breaker.ts`):
```typescript
const MAX_FAILURES = 3;
const WINDOW_MS = 5 * 60 * 1000; // 5 min

interface CircuitState {
  failures: number[];
  lastCheck: number;
}

const STORAGE_KEY = "p24_circuit";

export function isP24CircuitOpen(): boolean {
  if (typeof window === "undefined") return false;
  const stored = localStorage.getItem(STORAGE_KEY);
  if (!stored) return false;

  const state: CircuitState = JSON.parse(stored);
  const now = Date.now();
  const recentFailures = state.failures.filter(ts => now - ts < WINDOW_MS);

  return recentFailures.length >= MAX_FAILURES;
}

export function recordP24Failure(): void {
  if (typeof window === "undefined") return;
  const stored = localStorage.getItem(STORAGE_KEY);
  const state: CircuitState = stored ? JSON.parse(stored) : { failures: [], lastCheck: 0 };

  state.failures.push(Date.now());
  state.failures = state.failures.filter(ts => Date.now() - ts < WINDOW_MS);
  state.lastCheck = Date.now();

  localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
}

export function resetP24Circuit(): void {
  if (typeof window === "undefined") return;
  localStorage.removeItem(STORAGE_KEY);
}
```

**Usage** (`CheckoutForm.tsx`):
```typescript
const [p24CircuitOpen, setP24CircuitOpen] = useState(false);

useEffect(() => {
  setP24CircuitOpen(isP24CircuitOpen());
}, []);

async function handleSubmit() {
  try {
    // ... płatność
  } catch (error) {
    if (formData.paymentProvider === "pp_przelewy24") {
      recordP24Failure();
      setP24CircuitOpen(true);
    }
    throw error;
  }
}

// Disable P24 w PaymentSelector
<PaymentSelector
  disabledProviderIds={p24CircuitOpen ? ["pp_przelewy24"] : []}
  p24CircuitOpen={p24CircuitOpen}
/>
```

**NEVER**: Nie blokuj całego checkoutu gdy jeden provider failuje. Zawsze fallback na bank transfer.

