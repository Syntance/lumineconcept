### 4.2 Real-time Validation (onBlur)

**Problem**: User wypełnia cały formularz → klika „Dalej" → 5 błędów naraz → frustracja.

**Solution**: Walidacja `onBlur` per pole + error message OD RAZU.

**Validators** (`lib/validation/checkout-validators.ts`):
```typescript
export const PHONE_REGEX = /^(\+48)?[\s-]?\d{3}[\s-]?\d{3}[\s-]?\d{3}$/;
export const POSTAL_CODE_REGEX = /^\d{2}-?\d{3}$/;
export const NIP_REGEX = /^\d{10}$/;

export function validatePhone(phone: string): string | null {
  if (!phone.trim()) return "Numer telefonu jest wymagany";
  if (!PHONE_REGEX.test(phone)) return "Nieprawidłowy format (xxx-xxx-xxx)";
  return null;
}

export function validatePostalCode(code: string): string | null {
  if (!code.trim()) return "Kod pocztowy jest wymagany";
  if (!POSTAL_CODE_REGEX.test(code)) return "Nieprawidłowy format (xx-xxx)";
  return null;
}

export function validateNip(nip: string): string | null {
  const cleaned = nip.replace(/\D/g, "");
  if (!NIP_REGEX.test(cleaned)) return "NIP musi mieć 10 cyfr";

  // Checksum validation (PL algorithm)
  const weights = [6, 5, 7, 2, 3, 4, 5, 6, 7];
  const sum = weights.reduce((acc, w, i) => acc + w * parseInt(cleaned[i], 10), 0);
  const checksum = sum % 11;
  const lastDigit = parseInt(cleaned[9] || "0", 10);

  if (checksum !== lastDigit) return "NIP nieprawidłowy (błąd sumy kontrolnej)";
  return null;
}

export function getFieldValidationError(field: string, value: string): string | null {
  switch (field) {
    case "phone": return validatePhone(value);
    case "postal_code": return validatePostalCode(value);
    case "nip": return validateNip(value);
    case "email": return value.includes("@") ? null : "Nieprawidłowy email";
    default: return null;
  }
}
```

**Component** (`CheckoutForm.tsx`):
```tsx
const [fieldErrors, setFieldErrors] = useState<Record<string, string>>({});
const [touchedFields, setTouchedFields] = useState<Record<string, boolean>>({});

function handleFieldBlur(field: string, value: string) {
  setTouchedFields(prev => ({ ...prev, [field]: true }));
  const error = getFieldValidationError(field, value);
  setFieldErrors(prev => ({ ...prev, [field]: error || "" }));
  
  if (error) {
    trackFormFieldError(field, error);
  }
}

<input
  type="tel"
  value={formData.phone}
  onChange={e => setFormData(prev => ({ ...prev, phone: e.target.value }))}
  onBlur={e => handleFieldBlur("phone", e.target.value)}
  className={touchedFields.phone && fieldErrors.phone ? "border-red-500" : ""}
  aria-invalid={!!fieldErrors.phone}
  aria-describedby={fieldErrors.phone ? "phone-error" : undefined}
/>
{touchedFields.phone && fieldErrors.phone && (
  <p id="phone-error" className="text-sm text-red-600 mt-1">
    {fieldErrors.phone}
  </p>
)}
```

**NEVER**: Nie waliduj `onChange` (zbyt agresywne, user dostaje błąd po 1 znaku). `onBlur` to sweet spot.

