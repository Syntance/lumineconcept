**Test** (`tests/e2e/checkout.spec.ts`):
```typescript
import { test, expect } from "@playwright/test";

test("checkout happy path with P24", async ({ page }) => {
  // 1. Add to cart
  await page.goto("/produkty/test-product");
  await page.click('button:has-text("Dodaj do koszyka")');
  
  // 2. Go to checkout
  await page.goto("/checkout");
  
  // 3. Step 1: Fill address
  await page.fill('input[name="email"]', "test@example.com");
  await page.fill('input[name="first_name"]', "Jan");
  await page.fill('input[name="last_name"]', "Kowalski");
  await page.fill('input[name="phone"]', "123-456-789");
  await page.fill('input[name="address_1"]', "ul. Testowa 1");
  await page.fill('input[name="postal_code"]', "00-001");
  await page.fill('input[name="city"]', "Warszawa");
  await page.click('button:has-text("Dalej")');
  
  // 4. Step 2: Select delivery
  await expect(page.locator('text=Wybierz sposób dostawy')).toBeVisible();
  await page.click('label:has-text("Kurier InPost")');
  await page.click('button:has-text("Dalej")');
  
  // 5. Step 3: Select payment
  await expect(page.locator('text=Wybierz płatność')).toBeVisible();
  await page.click('label:has-text("Przelewy24")');
  
  // 6. Accept terms
  await page.check('input[type="checkbox"]:near(:text("Akceptuję Regulamin"))');
  await page.check('input[type="checkbox"]:near(:text("Zgadzam się na przetwarzanie"))');
  
  // 7. Turnstile (auto-pass in test)
  await page.waitForSelector('[data-testid="turnstile-success"]', { timeout: 10000 });
  
  // 8. Submit
  await page.click('button:has-text("Zapłać")');
  
  // 9. Wait for redirect to P24 (or confirmation page in test mode)
  await expect(page).toHaveURL(/\/checkout\/potwierdzenie/, { timeout: 30000 });
  
  // 10. Verify order confirmation
  await expect(page.locator('text=Zamówienie zostało złożone')).toBeVisible();
});
```

**Run**:
```bash
pnpm test:e2e
```

**NEVER**: Nie merguj bez green E2E na checkout. To critical path — każdy bug = strata revenue.

