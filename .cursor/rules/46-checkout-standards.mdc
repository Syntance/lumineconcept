## 5. PAYMENT PROVIDER INTEGRATION — Best Practices

### 5.1 Przelewy24 (P24) Module Structure

**Folder**: `apps/backend/src/modules/payment-p24/`

```
payment-p24/
├── index.ts          # Module definition
├── service.ts        # P24Service extends AbstractPaymentProvider
├── types.ts          # P24InitiatePaymentInput, P24StatusResponse
└── config.ts         # ENV variables, API URLs
```

**Service** (`service.ts`):
```typescript
import { AbstractPaymentProvider, PaymentProviderContext } from "@medusajs/framework";
import crypto from "crypto";

export class P24Service extends AbstractPaymentProvider {
  static identifier = "pp_przelewy24";

  private p24ApiUrl = process.env.P24_API_URL!;
  private p24MerchantId = parseInt(process.env.P24_MERCHANT_ID!, 10);
  private p24PosId = parseInt(process.env.P24_POS_ID!, 10);
  private p24Crc = process.env.P24_CRC!;

  async initiatePayment(context: PaymentProviderContext) {
    // 1. Pobierz świeże dane z DB (NIGDY z context.amount)
    const cart = await this.cartService.retrieve(context.resource_id);
    const amount = Math.round(cart.total); // Integer grosze

    // 2. Walidacja
    if (context.amount !== amount) {
      throw new Error(`Amount mismatch: client=${context.amount}, server=${amount}`);
    }

    // 3. Generate sign
    const sessionId = `${context.resource_id}-${Date.now()}`;
    const sign = crypto
      .createHash("md5")
      .update(`${sessionId}|${this.p24PosId}|${amount}|PLN|${this.p24Crc}`)
      .digest("hex");

    // 4. Register transaction
    const response = await fetch(`${this.p24ApiUrl}/transaction/register`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        merchantId: this.p24MerchantId,
        posId: this.p24PosId,
        sessionId,
        amount,
        currency: "PLN",
        description: `Zamówienie ${context.resource_id}`,
        email: cart.email,
        urlReturn: `${process.env.FRONTEND_URL}/checkout/potwierdzenie?cart_id=${context.resource_id}`,
        urlStatus: `${process.env.BACKEND_URL}/webhooks/p24`,
        sign,
      }),
      signal: AbortSignal.timeout(30_000), // TIMEOUT obowiązkowy
    });

    if (!response.ok) {
      throw new Error(`P24 register failed: ${response.statusText}`);
    }

    const data = await response.json() as { token: string };

    return {
      session_data: {
        session_id: sessionId,
        token: data.token,
        redirect_url: `${this.p24ApiUrl}/trnRequest/${data.token}`,
      },
    };
  }

  async getPaymentStatus(context: PaymentProviderContext) {
    const sessionId = context.data.session_id;
    
    // NIGDY nie ufaj query params — pull z API
    const response = await fetch(`${this.p24ApiUrl}/transaction/verify`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        sessionId,
        merchantId: this.p24MerchantId,
        posId: this.p24PosId,
      }),
      signal: AbortSignal.timeout(30_000),
    });

    const data = await response.json() as { status: string };
    
    return {
      status: data.status === "success" ? "captured" : "failed",
    };
  }

  async refundPayment(context: PaymentProviderContext, amount: number) {
    // Refund logic (admin only)
    // ...
  }
}
```

**NEVER**: Nie hardcoduj `P24_MERCHANT_ID` / `P24_CRC` w kodzie. Zawsze ENV.

