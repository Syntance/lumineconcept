### 3.3 Cookie Consent Banner (MUST)

**Component** (`CookieConsent.tsx`):
```typescript
"use client";
import { useState, useEffect } from "react";

export function CookieConsent() {
  const [show, setShow] = useState(false);

  useEffect(() => {
    const consent = localStorage.getItem("cookie_consent");
    if (!consent) setShow(true);
  }, []);

  function handleAccept() {
    localStorage.setItem("cookie_consent", "accepted");
    setShow(false);
    // Enable analytics
    if (typeof window !== "undefined" && window.posthog) {
      window.posthog.opt_in_capturing();
    }
  }

  function handleReject() {
    localStorage.setItem("cookie_consent", "rejected");
    setShow(false);
    if (typeof window !== "undefined" && window.posthog) {
      window.posthog.opt_out_capturing();
    }
  }

  if (!show) return null;

  return (
    <div className="fixed bottom-0 left-0 right-0 bg-white border-t p-4 z-50">
      <p className="text-sm mb-4">
        Używamy plików cookie do analizy ruchu i personalizacji treści. Szczegóły w{" "}
        <a href="/polityka-prywatnosci" className="underline">
          Polityce prywatności
        </a>
        .
      </p>
      <div className="flex gap-4">
        <button onClick={handleAccept} className="btn-primary">
          Akceptuję
        </button>
        <button onClick={handleReject} className="btn-secondary">
          Odrzuć
        </button>
      </div>
    </div>
  );
}
```

**Layout** (`app/layout.tsx`):
```tsx
import { CookieConsent } from "@/components/layout/CookieConsent";

export default function RootLayout({ children }: { children: React.ReactNode }) {
  return (
    <html>
      <body>
        {children}
        <CookieConsent />
      </body>
    </html>
  );
}
```

**Footer** — przycisk do re-open:
```typescript
// FooterCookieSettings.tsx
export function FooterCookieSettings() {
  function handleClick() {
    localStorage.removeItem("cookie_consent");
    window.location.reload();
  }

  return (
    <button onClick={handleClick} className="text-sm underline">
      Ustawienia cookies
    </button>
  );
}
```

**NEVER**: Nie blokuj całej strony do czasu akceptacji cookies (cookie wall → GDPR violation). Banner na dole, content accessible.

