```typescript
export function trackCheckoutStep(step: number, cartId: string) {
  if (typeof window === "undefined" || !window.posthog) return;
  
  window.posthog.capture("checkout_step", {
    step,
    step_name: step === 1 ? "address" : step === 2 ? "delivery" : "payment",
    cart_id: cartId,
  });
}

export function trackCheckoutStart(cartId: string, cartTotal: number) {
  if (typeof window === "undefined" || !window.posthog) return;
  
  window.posthog.capture("checkout_start", {
    cart_id: cartId,
    cart_total: cartTotal,
  });
}

export function trackPurchase(details: PurchaseDetails & { checkout_duration_seconds?: number }) {
  if (typeof window === "undefined" || !window.posthog) return;
  
  window.posthog.capture("purchase", {
    order_id: details.orderId,
    total: details.total,
    payment_provider: details.paymentProvider,
    checkout_duration_seconds: details.checkout_duration_seconds,
  });
}

export function trackFormFieldError(field: string, error: string) {
  if (typeof window === "undefined" || !window.posthog) return;
  
  window.posthog.capture("form_field_error", {
    field,
    error,
    location: "checkout",
  });
}
```

