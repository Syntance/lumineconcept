### 2.4 Payment Reconciliation Cron (MUST)

**Problem**: P24 webhook zginie (sieć, restart) → order wisi `pending` na wieczność.

**Solution**: Cron co 10-15 min pulluje status z P24 dla pending payments.

**Implementation** (`apps/backend/src/jobs/reconcile-p24-payments.ts`):
```typescript
import { completeCartWorkflow } from "@medusajs/medusa/core-flows";

export default async function reconcileP24PaymentsJob(container: MedusaContainer) {
  const logger = container.resolve("logger") as Logger;
  const query = container.resolve(ContainerRegistrationKeys.QUERY) as QueryGraph;

  // 1. Wiszące sesje P24 (pending)
  const { data: sessionRows } = await query.graph({
    entity: "payment_session",
    fields: ["id", "status", "provider_id", "created_at", "payment_collection_id"],
    filters: { provider_id: "przelewy24", status: "pending" },
    pagination: { take: 500, order: { created_at: "DESC" } },
  });

  const reconcilable = (sessionRows as P24SessionRow[]).filter(row => 
    isReconcilableSession(row, Date.now())
  );

  // 2. Sesja → koszyk (link)
  const collectionIds = [...new Set(reconcilable.map(r => r.payment_collection_id).filter(Boolean))];
  const { data: linkRows } = await query.graph({
    entity: "cart_payment_collection",
    fields: ["cart_id", "payment_collection_id"],
    filters: { payment_collection_id: collectionIds },
  });
  const cartIds = uniqueCartIds(linkRows);

  // 3. Tylko niedomknięte koszyki
  const { data: cartRows } = await query.graph({
    entity: "cart",
    fields: ["id", "completed_at"],
    filters: { id: cartIds },
  });
  const candidates = cartRows
    .filter(c => !c.completed_at)
    .slice(0, RECONCILE_MAX_PER_RUN);

  // 4. Próba domknięcia (completeCartWorkflow sam pulluje status)
  for (const cart of candidates) {
    try {
      const { result } = await completeCartWorkflow(container).run({
        input: { id: cart.id },
      });
      logger.info(`[p24-reconcile] koszyk ${cart.id} → zamówienie ${result.id}`);
    } catch (e) {
      const kind = classifyCompleteCartError(e);
      if (kind === "payment_pending" || kind === "already_completed") {
        continue; // normalny stan
      }
      logger.warn(`[p24-reconcile] koszyk ${cart.id}: ${(e as Error)?.message}`);
    }
  }
}

export const config = {
  name: "reconcile-p24-payments",
  schedule: "*/10 * * * *", // Co 10 min
};
```

**NEVER**: Nie polegaj tylko na webhookach. Zawsze reconciliation cron jako fallback.

