# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://medusa:medusa@localhost:5432/medusa_db

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Przelewy24
PRZELEWY24_MERCHANT_ID=
PRZELEWY24_POS_ID=
PRZELEWY24_API_KEY=
PRZELEWY24_CRC=
PRZELEWY24_SANDBOX=true

# PayPo
PAYPO_API_KEY=
PAYPO_SANDBOX=true

# InPost
INPOST_API_KEY=
INPOST_ORGANIZATION_ID=
INPOST_SANDBOX=true

# DPD
DPD_LOGIN=
DPD_PASSWORD=
DPD_FID=

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=masterKey

# Meta CAPI
META_CAPI_ACCESS_TOKEN=
META_PIXEL_ID=

# MailerLite
MAILERLITE_API_KEY=

# Jednorazowy bootstrap dostawy (DPD) — POST /admin/setup/shipping z nagłówkiem x-lumine-setup-secret
# Lokalnie możesz zamiast tego: pnpm --filter @lumine/backend setup-shipping
LUMINE_SETUP_SECRET=

# Wyłącza POST /store/custom/ensure-shipping (checkout sam woła przy braku opcji)
# LUMINE_DISABLE_PUBLIC_ENSURE_SHIPPING=true

# App
# Backend (Railway): https://medusa-backend-lumineconceptpl.up.railway.app
# STORE_CORS / AUTH_CORS muszą zawierać URL sklepu (Vercel), np. https://twoja-domena.vercel.app
MEDUSA_ADMIN_ONBOARDING_TYPE=default
# Lokalny admin do testów (tylko dev) — po db:migrate uruchom: pnpm admin:create-local
# Login w Medusa Admin: http://localhost:7001
MEDUSA_ADMIN_EMAIL=admin@local.test
MEDUSA_ADMIN_PASSWORD=admin
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:3000
COOKIE_SECRET=supersecret-change-me
JWT_SECRET=supersecret-change-me
