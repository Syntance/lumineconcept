# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://medusa:medusa@localhost:5432/medusa_db

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Przelewy24
PRZELEWY24_MERCHANT_ID=
PRZELEWY24_POS_ID=
PRZELEWY24_API_KEY=
PRZELEWY24_CRC=
PRZELEWY24_SANDBOX=true

# PayPo
PAYPO_API_KEY=
PAYPO_SANDBOX=true

# InPost
INPOST_API_KEY=
INPOST_ORGANIZATION_ID=
INPOST_SANDBOX=true

# DPD
DPD_LOGIN=
DPD_PASSWORD=
DPD_FID=

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=masterKey

# Meta CAPI
META_CAPI_ACCESS_TOKEN=
META_PIXEL_ID=

# MailerLite
MAILERLITE_API_KEY=

# ─── Resend — maile transakcyjne (potwierdzenie po złożeniu zamówienia itd.) ───
#
# 1) Konto: https://resend.com → API Keys → wklej poniżej.
# 2) Nadawca (FROM):
#    - Domyślnie w kodzie: Lumine Concept <kontakt@lumineconcept.pl> (nadpisz
#      RESEND_FROM jeśli chcesz inny adres z tej samej zweryfikowanej domeny).
#    - Domena lumineconcept.pl musi być zweryfikowana w Resend → Domains.
#    - Testy bez domeny: RESEND_FROM=Acme <onboarding@resend.dev> (limit Resend).
# 3) Wdróż zmienne na Railway (backend): RESEND_API_KEY, RESEND_FROM, opcjonalnie
#    RESEND_REPLY_TO, STOREFRONT_URL — i zrestartuj usługę (moduł Notification
#    ładuje się tylko przy starcie, gdy klucz jest ustawiony).
# 4) Po złożeniu zamówienia mail idzie z subscribera `order.placed` oraz z
#    zapasowego POST /store/custom/notify-order-placed (storefront). Wymaga
#    działającego workera Redis (ten sam proces co `medusa start` na Railway).
#
RESEND_API_KEY=
# Opcjonalne — gdy puste, backend używa Lumine Concept <kontakt@lumineconcept.pl>
# RESEND_FROM=Lumine Concept <kontakt@lumineconcept.pl>
# Opcjonalne — adres „Odpowiedz do” (często ten sam co nadawca).
# RESEND_REPLY_TO=kontakt@lumineconcept.pl

# URL publiczny storefrontu — link „Wróć do sklepu” w mailach.
# STOREFRONT_URL=https://lumineconcept.pl

# Jednorazowy bootstrap dostawy (DPD) — POST /admin/setup/shipping z nagłówkiem x-lumine-setup-secret
# Lokalnie możesz zamiast tego: pnpm --filter @lumine/backend setup-shipping
LUMINE_SETUP_SECRET=

# Wyłącza POST /store/custom/ensure-shipping (checkout sam woła przy braku opcji)
# LUMINE_DISABLE_PUBLIC_ENSURE_SHIPPING=true

# Wyłącza POST /store/custom/ensure-payment (checkout sam woła przy braku providera)
# LUMINE_DISABLE_PUBLIC_ENSURE_PAYMENT=true

# Revalidacja cache storefrontu po mutacjach produktów (Medusa subscriber → Next.js webhook)
# STOREFRONT_REVALIDATE_URL=https://lumineconcept.pl/api/revalidate/medusa
# MEDUSA_REVALIDATE_SECRET=change-me

# Sentry (opcjonalnie) — brak DSN ⇒ kod jest no-op, nic nie wysyłamy.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.05

# App
# Backend (Railway): https://medusa-backend-lumineconceptpl.up.railway.app
# STORE_CORS / AUTH_CORS muszą zawierać URL sklepu (Vercel), np. https://twoja-domena.vercel.app
MEDUSA_ADMIN_ONBOARDING_TYPE=default
# Lokalny admin do testów (tylko dev) — po db:migrate uruchom: pnpm admin:create-local
# Login w Medusa Admin: http://localhost:7001
MEDUSA_ADMIN_EMAIL=admin@local.test
MEDUSA_ADMIN_PASSWORD=admin
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:3000
COOKIE_SECRET=supersecret-change-me
JWT_SECRET=supersecret-change-me

# Taksonomia kategorii (gotowe-wzory / logo-3d / certyfikaty) — uruchom na tej samej bazie co Medusa Admin:
#   pnpm sync-medusa-categories
#   pnpm sync-medusa-categories:link   # opcjonalnie: przypisz produkty
