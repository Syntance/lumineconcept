# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://medusa:medusa@localhost:5432/medusa_db

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# Przelewy24
PRZELEWY24_MERCHANT_ID=
PRZELEWY24_POS_ID=
PRZELEWY24_API_KEY=
PRZELEWY24_CRC=
PRZELEWY24_SANDBOX=true

# PayPo
PAYPO_API_KEY=
PAYPO_SANDBOX=true

# InPost
INPOST_API_KEY=
INPOST_ORGANIZATION_ID=
INPOST_SANDBOX=true

# DPD
DPD_LOGIN=
DPD_PASSWORD=
DPD_FID=

# ─── Cloudflare R2 — trwałe przechowywanie plików (zdjęcia produktów, logo klientów) ───
#
# DLACZEGO: domyślny `file-local` zapisuje pliki na dysku Railway, który jest
# EFEMERYCZNY — przepadają przy każdym redeploy. R2 (S3-compatible) daje trwały,
# off-site storage. Gdy te zmienne są PUSTE, backend używa `file-local` (dev).
#
# KONFIGURACJA (Cloudflare dashboard):
#  1. R2 → Create bucket (np. `lumine-media`).
#  2. Bucket → Settings → Public access: podłącz Custom Domain (np. media.lumineconcept.pl)
#     lub włącz r2.dev subdomain. Ten publiczny URL → S3_FILE_URL.
#  3. R2 → Manage API Tokens → Create token (Object Read & Write, ten bucket).
#     Token daje Access Key ID + Secret Access Key.
#  4. Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Publiczny bazowy URL plików (custom domain R2 lub https://pub-xxxx.r2.dev)
S3_FILE_URL=
# Opcjonalny prefix dla wszystkich plików Medusy (np. "store/")
# S3_PREFIX=

# ─── Backup / Disaster Recovery (job backup-to-r2 + restore:verify) ───
#
# Backupy danych (produkty, zamówienia z PII) trafiają do R2 pod `backups/`.
# BACKUP_ENCRYPTION_KEY: 32 bajty (hex 64 znaki LUB base64) — szyfrowanie
#   klientowe AES-256-GCM PRZED wysłaniem do R2. Pusty = backup plaintext (NIE
#   zalecane dla PII). Wygeneruj: `openssl rand -hex 32`.
BACKUP_ENCRYPTION_KEY=
# Ile dni trzymać backupy w R2 (retencja). Domyślnie 30. 0 = bez czyszczenia.
BACKUP_RETENTION_DAYS=30
# Pełny zrzut bazy pg_dump do R2 (wymaga binarki pg_dump w środowisku). 1 = włącz.
BACKUP_PGDUMP=0
# Opcjonalne SSE na obiektach R2 (defense-in-depth; R2 szyfruje at-rest i tak). np. AES256
# S3_SSE=AES256

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=masterKey

# Meta CAPI
META_CAPI_ACCESS_TOKEN=
META_PIXEL_ID=

# MailerLite
MAILERLITE_API_KEY=

# ─── Resend — maile transakcyjne (potwierdzenie po złożeniu zamówienia itd.) ───
#
# 1) Konto: https://resend.com → API Keys → wklej poniżej.
# 2) Nadawca (FROM):
#    - Domyślnie w kodzie: Lumine Concept <kontakt@lumineconcept.pl> (nadpisz
#      RESEND_FROM jeśli chcesz inny adres z tej samej zweryfikowanej domeny).
#    - Domena lumineconcept.pl musi być zweryfikowana w Resend → Domains.
#    - Testy bez domeny: RESEND_FROM=Acme <onboarding@resend.dev> (limit Resend).
# 3) Wdróż zmienne na Railway (backend): RESEND_API_KEY, RESEND_FROM, opcjonalnie
#    RESEND_REPLY_TO, STOREFRONT_URL — i zrestartuj usługę (moduł Notification
#    ładuje się tylko przy starcie, gdy klucz jest ustawiony).
# 4) Po złożeniu zamówienia mail idzie z subscribera `order.placed` oraz z
#    zapasowego POST /store/custom/notify-order-placed (storefront). Wymaga
#    działającego workera Redis (ten sam proces co `medusa start` na Railway).
#
RESEND_API_KEY=
# Opcjonalne — gdy puste, backend używa Lumine Concept <kontakt@lumineconcept.pl>
# RESEND_FROM=Lumine Concept <kontakt@lumineconcept.pl>
# Opcjonalne — adres „Odpowiedz do” (często ten sam co nadawca).
# RESEND_REPLY_TO=kontakt@lumineconcept.pl

# Mail z danymi do przelewu (opcjonalne — domyślnie wartości z magazyn.config.ts)
# BANK_TRANSFER_RECIPIENT=Lumine Concept
# BANK_TRANSFER_IBAN=PL58105011001000009085809698
# BANK_TRANSFER_SWIFT=INGBPLPW
# BANK_TRANSFER_ADDRESS_LINE1=Jana Pawła II 93
# BANK_TRANSFER_ADDRESS_LINE2=34-115 Ryczów
# BANK_TRANSFER_PAYMENT_DAYS=5

# URL publiczny storefrontu — link „Wróć do sklepu” w mailach.
# Backend woła ${STOREFRONT_URL}/api/internal/order-email (szablony z magazynu).
# Secret: MEDUSA_REVALIDATE_SECRET (ten sam co webhook revalidate) lub ORDER_EMAIL_INTERNAL_SECRET.
# STOREFRONT_URL=https://lumineconcept.pl

# Jednorazowy bootstrap dostawy (DPD) — POST /admin/setup/shipping z nagłówkiem x-lumine-setup-secret
# Lokalnie możesz zamiast tego: pnpm --filter @lumine/backend setup-shipping
LUMINE_SETUP_SECRET=

# Publiczne endpointy bootstrapujące konfigurację sklepu. PO zweryfikowaniu
# setupu dostawy/płatności na PRODUKCJI ustaw obie na `true` (mutują konfigurację
# sklepu i bez tego są wywoływalne publicznie). Checkout woła je tylko jako
# fallback przy pierwszym uruchomieniu.
# LUMINE_DISABLE_PUBLIC_ENSURE_SHIPPING=true
# LUMINE_DISABLE_PUBLIC_ENSURE_PAYMENT=true

# ─── Upstash Redis (REST) — rate limiting endpointów store ───
# Wymagane dla globalnego rate-limitu (/store/custom/*, completeCart, prepare-checkout).
# Brak = fail-open (ruch przepuszczany). Pobierz z konsoli Upstash.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Revalidacja cache storefrontu po mutacjach produktów (Medusa subscriber → Next.js webhook)
# STOREFRONT_REVALIDATE_URL=https://lumineconcept.pl/api/revalidate/medusa
# MEDUSA_REVALIDATE_SECRET=change-me

# Sentry (opcjonalnie) — brak DSN ⇒ kod jest no-op, nic nie wysyłamy.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.05

# App
# Backend (Railway): https://medusa-backend-lumineconceptpl.up.railway.app
# STORE_CORS / AUTH_CORS muszą zawierać URL sklepu (Vercel), np. https://twoja-domena.vercel.app
MEDUSA_ADMIN_ONBOARDING_TYPE=default
# Lokalny admin do testów (tylko dev) — po db:migrate uruchom: pnpm admin:create-local
# Login w Medusa Admin: http://localhost:7001
MEDUSA_ADMIN_EMAIL=admin@local.test
MEDUSA_ADMIN_PASSWORD=admin
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:3000
COOKIE_SECRET=supersecret-change-me
JWT_SECRET=supersecret-change-me

# Taksonomia kategorii (gotowe-wzory / logo-3d / certyfikaty) — uruchom na tej samej bazie co Medusa Admin:
#   pnpm sync-medusa-categories
#   pnpm sync-medusa-categories:link   # opcjonalnie: przypisz produkty
