{
  "name": "@lumine/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Lumine Commerce — MedusaJS v2 Backend",
  "scripts": {
    "dev": "medusa develop",
    "start": "medusa start -H 0.0.0.0",
    "build": "medusa build",
    "seed": "medusa exec medusa-config -- medusa seed -f ./data/seed.json",
    "db:migrate": "medusa db:migrate",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo .medusa"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "^2.13.4",
    "@medusajs/cli": "^2.13.4",
    "@medusajs/dashboard": "^2.13.4",
    "@medusajs/framework": "^2.13.4",
    "@medusajs/medusa": "^2.13.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "cloudinary": "^2.9.0",
    "ioredis": "^5.10.1",
    "meilisearch": "^0.56.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@medusajs/types": "^2.13.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
