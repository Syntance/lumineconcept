{
  "name": "@lumine/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Lumine Commerce — MedusaJS v2 Backend",
  "scripts": {
    "dev": "medusa develop",
    "start": "medusa start",
    "build": "medusa build",
    "seed": "medusa exec medusa-config -- medusa seed -f ./data/seed.json",
    "db:migrate": "medusa db:migrate",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo .medusa"
  },
  "dependencies": {
    "@medusajs/framework": "^2.13.4",
    "@medusajs/medusa": "^2.13.4",
    "@medusajs/medusa-cli": "^1.3.23",
    "meilisearch": "^0.45.0",
    "cloudinary": "^2.5.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@medusajs/types": "^2.13.4",
    "typescript": "^5.7.3"
  }
}
