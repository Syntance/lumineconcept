# Medusa
# Lokalnie: http://localhost:9000 — klucz publishable z TEJ samej instancji (Settings → API keys)
# Produkcja (Railway): https://medusa-backend-lumineconceptpl.up.railway.app
#
# WAŻNE (dev): gdy uruchamiasz `pnpm dev` z backendem w monorepo, ustaw OBA URL na localhost:9000.
# Panel Magazyn i storefront wołają Medusę bezpośrednio — wskazanie na Railway przy lokalnym dev
# daje 502 „Application failed to respond” (cold start / limit czasu proxy).
#
# WAŻNE (Vercel): ta zmienna MUSI być ustawiona na produkcji. Przeglądarka woła
# Medusę bezpośrednio — inaczej każdy request idzie przez /api/medusa (limit
# czasu funkcji serwerowej) i przy długim checkout / cold start Railway dostajesz
# 504 „Application failed to respond” w konsoli.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Skopiuj tę samą wartość co wyżej (wymagane dla /api/medusa i getGlobalProductConfig)
MEDUSA_PUBLISHABLE_KEY=
# Opcjonalnie: jawny URL backendu dla Route Handler (domyślnie = NEXT_PUBLIC_*)
MEDUSA_BACKEND_URL=
# Jeśli `next dev` nie jest na porcie 3000
# PORT=3001
NEXT_PUBLIC_MEDUSA_REGION_ID=
# Konto serwisowe do cache'owanego odczytu CMS (Store.metadata) — musi istnieć w Medusie Admin.
# Lokalnie: po `pnpm db:migrate` uruchom `pnpm admin:create-local` (domyślnie admin@local.test / admin).
MEDUSA_ADMIN_EMAIL=admin@local.test
MEDUSA_ADMIN_PASSWORD=admin

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=

# Webhook z backendu Medusy po mutacji produktu → revalidateTag
MEDUSA_REVALIDATE_SECRET=

# Deploy Hook Vercel — ręczny Redeploy CMS/SEO w panelu Magazyn (prebuild sync obrazów).
# Utwórz w Vercel: Project → Settings → Git → Deploy Hooks → nazwa np. cms-save, branch main.
# Wklej URL hooka (POST) — tylko server-side, nie NEXT_PUBLIC_.
VERCEL_DEPLOY_HOOK_URL=

# ─── Upload plików klienta na PDP (logo do produktu) ───
# Kolejność wyboru backendu: 1) R2 (S3_*), 2) Vercel Blob, 3) Medusa /admin/uploads (dev).
#
# Cloudflare R2 — WYMAGANE dla uploadu zdjęć CMS (hero, galeria, OG) lokalnie i na prod.
# Te same wartości co na backendzie (Railway). Bez S3_* upload CMS w panelu nie zadziała.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FILE_URL=
# Ta sama wartość co S3_FILE_URL — wymagana na Vercel storefront (next/image + CSP).
# Bez tego zdjęcia z CMS (upload przez Medusa/R2) nie wyświetlą się na produkcji.
NEXT_PUBLIC_S3_FILE_URL=
# CORS na bucket R2 (Settings → CORS) — wymagane dla uploadu CMS > 4 MB bez kompresji:
# AllowedOrigins: https://lumineconcept.pl, https://www.lumineconcept.pl, https://lumine.syntance.dev, http://localhost:3000
# AllowedMethods: GET, PUT, HEAD — AllowedHeaders: *
# Alternatywa, gdy nie używasz R2:
BLOB_READ_WRITE_TOKEN=

# Meilisearch
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=

# Analytics — storefront (przeglądarka, po zgodzie cookies)
NEXT_PUBLIC_GA4_ID=G-XXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# Ingest przez reverse proxy na własnej domenie (next.config rewrites → /ingest).
# Zostaw puste lub ustaw /ingest — NIE ustawiaj https://eu.i.posthog.com w prod (adblocki).
# NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Analytics — panel Magazyn /statystyki (server-only)
# FEATURE_ANALYTICS_PANEL=0 wyłącza pobieranie GA4/PostHog w panelu
FEATURE_ANALYTICS_PANEL=1
# GA4 Data API (osobne od NEXT_PUBLIC_GA4_ID — numeric property ID + service account)
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=
# PostHog Query API — opcjonalne nadpisania (domyślnie: NEXT_PUBLIC_POSTHOG_* / POSTHOG_API_KEY)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
# POSTHOG_HOST=https://eu.posthog.com
# Pixel Meta (publiczny — ten sam ID co w Events Manager)
NEXT_PUBLIC_META_PIXEL_ID=870951479233197
# Segment biznesowy eventów (beauty | edu)
NEXT_PUBLIC_ANALYTICS_SEGMENT=beauty
# Meta CAPI — browser (Lead/Contact/Signup) + flagi
NEXT_PUBLIC_CAPI_ENABLED=false
# Opcjonalny override serwera — jeśli pominięty, /api/capi spada na NEXT_PUBLIC_CAPI_ENABLED.
# CAPI_ENABLED=false
CAPI_ALLOWED_ORIGINS=https://lumineconcept.pl,https://lumine.syntance.dev,http://localhost:3000
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
META_CAPI_ACCESS_TOKEN=
# Opcjonalny secret server-to-server (NIE używany przez browser /api/capi)
CAPI_SHARED_SECRET=

# Formularz kontaktowy (strona główna) — wysyłka przez Resend (jak zamówienia z backendu).
# Na Vercel ustaw te same wartości co przy mailach transakcyjnych, jeśli macie zweryfikowaną domenę.
RESEND_API_KEY=
RESEND_FROM=Lumine Concept <kontakt@lumineconcept.pl>
# Alternatywa: sam adres (bez RESEND_FROM)
# RESEND_FROM_EMAIL=kontakt@lumineconcept.pl
# RESEND_REPLY_TO=kontakt@lumineconcept.pl
# Opcjonalnie inny skrzynka niż kontakt@ — domyślnie używana jest kontakt@lumineconcept.pl
# CONTACT_INBOX_EMAIL=

# MailerLite
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Sentry — brak DSN = Sentry nie jest inicjalizowany, kod jest no-op.
# Publiczny DSN trafia do klienta (`NEXT_PUBLIC_`), serwerowy DSN trzymamy
# osobno, żeby móc rozdzielić projekt „storefront-client" od „storefront-server".
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Wspólne (nie są publiczne; używane przy build i runtime server).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Opcjonalne
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=0

# General
NEXT_PUBLIC_SITE_URL=https://lumineconcept.pl

# Przelew tradycyjny — IBAN (publiczny, checkout + mail). Alternatywa: magazyn.config.ts → bankTransfer.iban
NEXT_PUBLIC_BANK_TRANSFER_IBAN=

# Cloudflare Turnstile — OPCJONALNA captcha w checkoucie. Domyślnie WYŁĄCZONA
# (rate-limit per IP wystarcza; captcha kosztuje konwersję). Ustaw OBA klucze,
# aby włączyć. Sekret żyje w backendzie (apps/backend/.env).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
