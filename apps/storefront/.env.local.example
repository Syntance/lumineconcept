# Medusa
# Lokalnie: http://localhost:9000 — klucz publishable z TEJ samej instancji (Settings → API keys)
# Produkcja (Railway): https://medusa-backend-lumineconceptpl.up.railway.app
#
# WAŻNE (Vercel): ta zmienna MUSI być ustawiona na produkcji. Przeglądarka woła
# Medusę bezpośrednio — inaczej każdy request idzie przez /api/medusa (limit
# czasu funkcji serwerowej) i przy długim checkout / cold start Railway dostajesz
# 504 „Application failed to respond” w konsoli.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Skopiuj tę samą wartość co wyżej (wymagane dla /api/medusa i getGlobalProductConfig)
MEDUSA_PUBLISHABLE_KEY=
# Opcjonalnie: jawny URL backendu dla Route Handler (domyślnie = NEXT_PUBLIC_*)
MEDUSA_BACKEND_URL=
# Jeśli `next dev` nie jest na porcie 3000
# PORT=3001
NEXT_PUBLIC_MEDUSA_REGION_ID=

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=

# Webhook z backendu Medusy po mutacji produktu → revalidateTag
MEDUSA_REVALIDATE_SECRET=

# ─── Upload plików klienta na PDP (logo do produktu) ───
# Kolejność wyboru backendu: 1) R2 (S3_*), 2) Vercel Blob, 3) Medusa /admin/uploads (dev).
#
# Cloudflare R2 — preferowane na produkcji (trwałe, off-site, ten sam bucket co backend).
# Te same wartości co na backendzie (Railway). Klient wrzuca pod prefix `customer-uploads/`.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FILE_URL=
# Ta sama wartość co S3_FILE_URL — wymagana na Vercel storefront (next/image + CSP).
# Bez tego zdjęcia z CMS (upload przez Medusa/R2) nie wyświetlą się na produkcji.
NEXT_PUBLIC_S3_FILE_URL=
# Alternatywa, gdy nie używasz R2:
BLOB_READ_WRITE_TOKEN=

# Meilisearch
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
# Ingest EU (nie mylić z https://eu.posthog.com — to tylko panel webowy)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Pixel Meta (ten sam ID co w Events Manager — publiczny)
# Zostaw pusty w dev, żeby nie wysyłać „testowego" ruchu do produkcyjnego konta.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
CAPI_SHARED_SECRET=

# Formularz kontaktowy (strona główna) — wysyłka przez Resend (jak zamówienia z backendu).
# Na Vercel ustaw te same wartości co przy mailach transakcyjnych, jeśli macie zweryfikowaną domenę.
RESEND_API_KEY=
RESEND_FROM=Lumine Concept <kontakt@lumineconcept.pl>
# Alternatywa: sam adres (bez RESEND_FROM)
# RESEND_FROM_EMAIL=kontakt@lumineconcept.pl
# RESEND_REPLY_TO=kontakt@lumineconcept.pl
# Opcjonalnie inny skrzynka niż kontakt@ — domyślnie używana jest kontakt@lumineconcept.pl
# CONTACT_INBOX_EMAIL=

# MailerLite
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Sentry — brak DSN = Sentry nie jest inicjalizowany, kod jest no-op.
# Publiczny DSN trafia do klienta (`NEXT_PUBLIC_`), serwerowy DSN trzymamy
# osobno, żeby móc rozdzielić projekt „storefront-client" od „storefront-server".
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Wspólne (nie są publiczne; używane przy build i runtime server).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Opcjonalne
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=0

# General
NEXT_PUBLIC_SITE_URL=https://lumineconcept.pl

# Przelew tradycyjny — IBAN (publiczny, checkout + mail). Alternatywa: magazyn.config.ts → bankTransfer.iban
NEXT_PUBLIC_BANK_TRANSFER_IBAN=
