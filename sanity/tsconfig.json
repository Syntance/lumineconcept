{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Sanity używa `defineField`/`defineType` z bardzo szerokim `unknown`
    // w callbackach `prepare`/`validation`. Uruchamianie `strict: true` tu
    // daje lawinę fałszywych błędów, które są niezależne od naszej logiki
    // runtime'u sklepu — dlatego type-check studia jest luźniejszy.
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": "./dist"
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
