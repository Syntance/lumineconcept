# Skopiuj do scripts/fill-product-seo.env i uzupełnij (plik jest w .gitignore).

# URL backendu Medusa (lokalnie lub Railway prod)
MEDUSA_BACKEND_URL=http://localhost:9000

# Dane admina Medusa
MEDUSA_ADMIN_EMAIL=twoj@email.pl
MEDUSA_ADMIN_PASSWORD=twoje-haslo

# DRY_RUN=1   — tylko podgląd, nie zapisuje nic do bazy
# DRY_RUN=0   — tryb zapisu (domyślny po ustawieniu emaila/hasła)
DRY_RUN=1

# FORCE=1     — nadpisuje istniejące SEO (domyślnie pomija produkty z uzupełnionym meta title)
# FORCE=0
FORCE=0

# HANDLE=xxx  — aktualizuj tylko jeden produkt (np. HANDLE=zawieszka-na-drzwi)
# HANDLE=
