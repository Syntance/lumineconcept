{
  "name": "lumine-commerce",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "start": "pnpm --filter @lumine/backend start",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "sync-medusa-product": "tsx scripts/sync-medusa-product-from-source.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
