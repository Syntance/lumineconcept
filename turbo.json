{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_MEDUSA_BACKEND_URL",
        "MEDUSA_BACKEND_URL",
        "NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY",
        "MEDUSA_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_MEDUSA_REGION_ID",
        "NEXT_PUBLIC_SANITY_PROJECT_ID",
        "NEXT_PUBLIC_SANITY_DATASET",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_MEILISEARCH_HOST",
        "NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "NEXT_PUBLIC_META_PIXEL_ID",
        "SANITY_API_TOKEN",
        "SANITY_REVALIDATE_SECRET",
        "MEDUSA_REVALIDATE_SECRET",
        "MEDUSA_ADMIN_EMAIL",
        "MEDUSA_ADMIN_PASSWORD",
        "META_CAPI_ACCESS_TOKEN",
        "CAPI_SHARED_SECRET",
        "MAILERLITE_API_KEY",
        "MAILERLITE_GROUP_ID",
        "CLOUDINARY_CLOUD_NAME",
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "PRZELEWY24_MERCHANT_ID",
        "PRZELEWY24_POS_ID",
        "PRZELEWY24_API_KEY",
        "PRZELEWY24_CRC",
        "PRZELEWY24_SANDBOX",
        "RESEND_API_KEY",
        "RESEND_FROM",
        "RESEND_FROM_EMAIL",
        "S3_ENDPOINT",
        "S3_REGION",
        "S3_BUCKET",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_FILE_URL",
        "NEXT_PUBLIC_S3_FILE_URL",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_SENTRY_ENVIRONMENT",
        "NEXT_PUBLIC_SENTRY_RELEASE",
        "NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE",
        "NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE",
        "NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ENVIRONMENT",
        "SENTRY_RELEASE",
        "SENTRY_TRACES_SAMPLE_RATE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
